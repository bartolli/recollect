# recollect environment configuration
# Copy to .env and fill in the required values.
# All optional vars override config.toml defaults; leave commented to use defaults.
# For bulk config changes, prefer a memory.toml file (set MEMORY_CONFIG below).

# ---------------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------------

# PostgreSQL connection string.
DATABASE_URL=postgresql://user@localhost:5432/memory_v3

# pydantic-ai model string in provider:model format.
# This drives all LLM extraction (entities, concepts, persona facts, recall tokens).
# Examples:
#   anthropic:claude-haiku-4-5-20251001
#   openai:gpt-4o-mini
#   ollama:ministral-3
#   groq:llama-3.3-70b-versatile
#   google-gla:gemini-2.0-flash
#   mistral:mistral-small-latest
#   deepseek:deepseek-chat
PYDANTIC_AI_MODEL=anthropic:claude-haiku-4-5-20251001

# ---------------------------------------------------------------------------------
# PROVIDER CREDENTIALS
# Set the vars that match your PYDANTIC_AI_MODEL prefix.
# All of these are read directly by pydantic-ai, not the recollect config system.
# ---------------------------------------------------------------------------------

# -- Anthropic (anthropic:...) ---------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# Custom endpoint, proxy, or enterprise gateway. Default: api.anthropic.com
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# -- OpenAI (openai:...) ---------------------------------------------------------
# OPENAI_API_KEY=sk-proj-...
# Custom base URL. Use this to point openai:... at any OpenAI-compatible server
# (vLLM, LM Studio, LocalAI, etc.) without needing the ollama:... prefix.
# Default: https://api.openai.com/v1
# OPENAI_BASE_URL=http://localhost:8080/v1

# -- Ollama (ollama:...) ---------------------------------------------------------
# Required when using ollama:... models. No default -- must be set explicitly.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# For Ollama Cloud, set the API key:
# OLLAMA_API_KEY=your-key

# -- Groq (groq:...) -------------------------------------------------------------
# GROQ_API_KEY=gsk_...

# -- Google / Gemini (google-gla:... or google-vertex:...) -----------------------
# GOOGLE_API_KEY=AIza...

# -- Mistral (mistral:...) -------------------------------------------------------
# MISTRAL_API_KEY=...

# -- DeepSeek (deepseek:...) -----------------------------------------------------
# Useful for reasoning models (DeepSeek-R1). Increase MEMORY_EXTRACTION_MAX_TOKENS
# to 16384 when using reasoning models to account for thinking token overhead.
# DEEPSEEK_API_KEY=sk-...

# ---------------------------------------------------------------------------------
# MCP SERVER
# Required when running recollect-mcp. Not needed for SDK-only use.
# ---------------------------------------------------------------------------------

# Scopes all memory operations to this user. Server refuses to start without it.
# MEMORY_USER_ID=your-user-id

# Bind address for streamable-http transport.
# Defaults: localhost / 8000
# SERVER_HOST=localhost
# SERVER_PORT=8000

# ---------------------------------------------------------------------------------
# EXTRACTION TUNING
# ---------------------------------------------------------------------------------

# Max tokens for LLM extraction calls.
# Reasoning models (Qwen3, DeepSeek-R1, o1/o3) consume thinking tokens before
# producing output. Default 8192 covers most cases; increase to 16384 if you see
# empty extraction results with a reasoning model.
# Default: 8192
# MEMORY_EXTRACTION_MAX_TOKENS=8192

# Override the extraction prompt instructions appended to the system prompt.
# Use this to customize entity types, category definitions, or domain vocabulary
# without forking the extraction code.
# Default: built-in instructions (see config.toml extraction.instructions)
# MEMORY_EXTRACTION_INSTRUCTIONS=

# ---------------------------------------------------------------------------------
# STARTUP
# ---------------------------------------------------------------------------------

# Set to 1 after the embedding model (nomic-embed-text-v1.5-Q) has been cached
# locally. Skips HuggingFace HTTP checks on every server start.
# Default: unset (checks on startup)
# HF_HUB_OFFLINE=1

# Path to a custom TOML config file. Overrides memory.toml in the working directory.
# Use for bulk parameter changes instead of setting individual env vars.
# Default: memory.toml in working directory, then built-in config.toml
# MEMORY_CONFIG=/path/to/memory.toml

# ---------------------------------------------------------------------------------
# RECALL TOKENS (ADVANCED)
# Controls the Hebbian recall token mechanism. Defaults are tuned for production.
# Only change these if you are actively tuning retrieval behaviour.
# ---------------------------------------------------------------------------------

# Disable the recall token mechanism entirely.
# Default: true
# MEMORY_RECALL_TOKENS_ENABLED=true

# Number of similar existing traces considered for token assessment at write time.
# Default: 5
# MEMORY_RECALL_TOKENS_TOP_K=5

# Minimum cosine similarity for a trace to be considered related at write time.
# Lower values create more token groups; higher values are more selective.
# Default: 0.42
# MEMORY_RECALL_TOKENS_THRESHOLD=0.42

# Minimum token strength to activate at query time. Tokens below this are skipped.
# Default: 0.1
# MEMORY_RECALL_TOKENS_STRENGTH_THRESHOLD=0.1

# Strength increment when a token participates in a successful recall (capped at 1.0).
# Default: 0.1
# MEMORY_RECALL_TOKENS_REINFORCE_BOOST=0.1

# Strength multiplier applied to inactive tokens during each consolidation pass.
# Tokens that decay below 0.01 are archived.
# Default: 0.9
# MEMORY_RECALL_TOKENS_DECAY_FACTOR=0.9

# Signal attenuation per hop during token propagation.
# Default: 0.85
# MEMORY_RECALL_TOKENS_HOP_DECAY=0.85

# Weight of propagated token signal in the additive score blend.
# Default: 0.50
# MEMORY_RECALL_TOKENS_PROPAGATION_BLEND=0.50

# Maximum re-seeding rounds during iterative token propagation.
# Default: 3
# MEMORY_RECALL_TOKENS_MAX_ROUNDS=3

# Top-K overlap fraction required to stop iterating early (0.95 = 95% stable).
# Default: 0.95
# MEMORY_RECALL_TOKENS_STABILITY_THRESHOLD=0.95

# Number of token-discovered traces used as seeds in each re-seeding round.
# Default: 3
# MEMORY_RECALL_TOKENS_TOP_SEEDS=3

# Override the system and user prompts for write-time token assessment.
# Leave unset to use the built-in prompts.
# MEMORY_RECALL_TOKENS_SYSTEM_PROMPT=
# MEMORY_RECALL_TOKENS_USER_PROMPT=
